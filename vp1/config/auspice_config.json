    }
  ],
  "data_provenance": [
    {
      "name": "GenBank",
      "url": "https://www.ncbi.nlm.nih.gov/genbank/"
    }
  ],
  "build_url": "https://github.com/hodcroftlab/coxsackievirus_a10/tree/master",
  "colorings": [
    {
      "key": "gt",
      "title": "Subgenotype",
      "type": "categorical"
    }, 
    {
      "key": "published_clade",
      "title": "Published Clades",
      "type": "categorical"
    }, 
    {
      "key": "country",
      "title": "Country",
      "type": "categorical"
    },
    {
      "key": "region",
      "title": "Global Regions",
      "type": "categorical"
    },
    {
      "key": "isolate-lineage-source",
      "title": "Isolation Source",
      "type": "categorical"
    },
    {
      "key": "age",
      "title": "Age (years)",
      "type": "continuous",
      "scale": [
        [0, "#3f63cf"],
        [0.125, "#3f63cf"],
        [0.375, "#529ab6"],
        [0.75, "#75b681"],
        [3, "#a6be55"],
        [7.5, "#d4b13f"],
        [13.5, "#e68133"],
        [20, "#dc2f24"]
      ],
      "legend": [
        {"value": 0.125, "display": "0-3 m/o", "bounds":  [0, 0.25]},
        {"value": 0.375, "display": "4-6 m/o", "bounds":  [0.25, 0.5]},
        {"value":  0.75, "display": "7-12 m/o", "bounds":  [0.5, 1]},
        {"value": 3, "display": "1-5 y/o", "bounds": [1, 5]},
        {"value": 7.5, "display": "6-10 y/o", "bounds": [5, 10]},
        {"value": 13.5, "display": "11-17 y/o", "bounds": [10, 17]},
        {"value": 20, "display": "18+ y/o", "bounds": [17, 100]}
      ]
    },
    {
      "key": "gender",
      "title": "Gender",
      "type": "categorical"
    },
    {
      "key": "diagnosis",
      "title": "Symptoms",
      "type": "categorical"
    },
    {
      "key": "length",
      "title": "NCBI-reported Length",
      "type": "continuous"
    },
    {
      "key": "author",
      "title": "Authors",
      "type": "categorical"
    }  ],
  "geo_resolutions": [
    {
      "key": "country",
      "title": "Country"
    },
    {
      "key": "location",
      "title": "Areas"
    },
    {
      "key": "region",
      "title": "Global Regions"
    }
  ],
  "panels": [
    "tree",
    "map",
    "entropy"
  ],
  "display_defaults": {
    "color_by": "clade_membership",
    "geo_resolution": "country",
    "tip_label": "strain",
    "map_triplicate": true
  },
  "metadata_columns": [
    "strain"
  ],
  "filters": [
    "country",
    "region",
    "author"
  ]
}
